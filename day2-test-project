# 4. Registration Form (register.php)

<?php
session_start();
require_once "config.php";

if(empty($_SESSION['csrf_token'])) {
    $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
}

$message = "";

if($_SERVER["REQUEST_METHOD"] == "POST") {

    if(
        !isset($_POST['csrf_token']) ||
        !hash_equals($_SESSION['csrf_token'], $_POST['csrf_token'])
    ){
        die("Invalid CSRF Token");
    }

    $name = trim($_POST['name']);
    $email = trim($_POST['email']);
    $age = trim($_POST['age']);

    $errors = [];

    // Name Validation
    if(empty($name)) {
        $errors[] = "Name is required";
    }

    if(strlen($name) > 100) {
        $errors[] = "Name too long";
    }

    // Email Validation
    if(!filter_var($email, FILTER_VALIDATE_EMAIL)) {
        $errors[] = "Invalid Email";
    }

    // Age Validation
    if(!filter_var($age, FILTER_VALIDATE_INT)) {
        $errors[] = "Invalid Age";
    }

    if($age < 18 || $age > 100) {
        $errors[] = "Age must be between 18 and 100";
    }

    // File Validation
    if(isset($_FILES['idproof']) && $_FILES['idproof']['error'] === 0) {

        $allowedTypes = [
            'image/jpeg',
            'image/png',
            'application/pdf'
        ];

        $fileType = mime_content_type($_FILES['idproof']['tmp_name']);

        if(!in_array($fileType, $allowedTypes)) {
            $errors[] = "Only JPG, PNG and PDF allowed";
        }

        if($_FILES['idproof']['size'] > 2 * 1024 * 1024) {
            $errors[] = "File size should not exceed 2MB";
        }

    } else {
        $errors[] = "ID Proof is required";
    }

    if(empty($errors)) {

        $extension = pathinfo(
            $_FILES['idproof']['name'],
            PATHINFO_EXTENSION
        );

        $newFileName = bin2hex(random_bytes(16))
                     . "." .
                     strtolower($extension);

        $uploadPath = "uploads/" . $newFileName;

        move_uploaded_file(
            $_FILES['idproof']['tmp_name'],
            $uploadPath
        );

        $stmt = $pdo->prepare("
            INSERT INTO users
            (full_name,email,age,id_proof)
            VALUES
            (:name,:email,:age,:idproof)
        ");

        $stmt->execute([
            ':name' => $name,
            ':email' => $email,
            ':age' => $age,
            ':idproof' => $newFileName
        ]);

        $message = "Registration Successful";

    } else {

        $message = implode("<br>", $errors);
    }
}
?>

